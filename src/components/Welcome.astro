---
import logo from '../assets/logo.svg';
---

<div id="container">
	<header class="mobile-home-header" aria-label="Homepage identity">
		<div class="mobile-brand" aria-hidden="true">
			<img src={logo.src} width="44" height="44" alt="" />
			<div class="mobile-brand-copy">
				<p class="mobile-brand-name">Alfredo Navas</p>
				<p class="mobile-brand-role">Product Builder</p>
			</div>
		</div>
	</header>

	<main>
		<section id="hero">
			<div class="hero-title">
				<img src={logo.src} width="63" height="63" alt="" aria-hidden="true" />
				<h1>Hi, I'm Alfredo Navas, Product Builder.</h1>
			</div>

			<div class="hero-copy">
				<p>
					Welcome to my personal website! Here, I share my journey as a product builder, insights on
					technology, and my passion for creating innovative solutions. Ask me anything about my work or
					projects.
				</p>
			</div>
		</section>
	</main>
</div>

<style>
	#container,
	main {
		height: 100%;
	}

	#container {
		display: flex;
		flex-direction: column;
	}

	.mobile-home-header {
		display: none;
	}

	main {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		min-height: clamp(20rem, 56vh, 36rem);
		padding: var(--space-12) var(--space-8) var(--space-8);
	}

	#hero {
		width: min(100%, 50rem);
		display: flex;
		flex-direction: column;
		color: var(--color-text);
	}

	.hero-title {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		min-height: 3.9375rem;
		padding-left: 1.0625rem;
	}

	.hero-title img {
		flex: 0 0 auto;
		width: 3.9375rem;
		height: 3.9375rem;
	}

	h1 {
		font-family: var(--font-family-sans);
		font-size: 2.25rem;
		line-height: 1.15;
		font-weight: 700;
	}

	.hero-copy {
		margin-top: 2.5625rem;
		display: grid;
		row-gap: 0;
	}

	p {
		font-family: var(--font-family-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-base);
		font-weight: var(--font-weight-regular);
	}

	@media (max-width: 48rem) {
		.mobile-home-header {
			display: flex;
			align-items: center;
			justify-content: flex-start;
			min-height: 3rem;
			margin-bottom: var(--space-8);
		}

		.mobile-brand {
			display: inline-flex;
			align-items: center;
			gap: 0.75rem;
		}

		.mobile-brand img {
			width: 2.75rem;
			height: 2.75rem;
			border-radius: 999px;
		}

		.mobile-brand-copy {
			display: grid;
			gap: 0.125rem;
		}

		.mobile-brand-name {
			font-size: var(--font-size-sm);
			line-height: var(--line-height-sm);
			font-weight: 500;
			color: var(--color-text);
		}

		.mobile-brand-role {
			font-size: var(--font-size-xs);
			line-height: var(--line-height-xs);
			color: var(--color-text-subtle);
		}

		main {
			flex: 1;
			min-height: auto;
			padding: 0;
			align-items: center;
		}

		#hero {
			width: min(100%, 23rem);
			align-items: center;
			text-align: center;
		}

		.hero-title {
			flex-direction: column;
			align-items: center;
			gap: var(--space-8);
			min-height: 0;
			padding-left: 0;
		}

		.hero-title img {
			width: 4.5rem;
			height: 4.5rem;
		}

		.hero-copy {
			margin-top: var(--space-7);
			max-width: 20rem;
		}

		h1 {
			max-width: 12.5ch;
			font-size: clamp(2rem, 8vw, 2.35rem);
			line-height: 1.16;
			text-wrap: balance;
		}

		p {
			font-size: 1.05rem;
			line-height: 1.6;
		}
	}
</style>
