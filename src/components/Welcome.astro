---
import { Image } from 'astro:assets';
import logo from '../assets/logo.svg';
---

<div id="container">
	<div class="hero-shell">
		<section id="hero">
			<div class="hero-title">
				<span class="hero-skull-wrap" aria-hidden="true">
					<Image class="hero-skull" src={logo} width={63} height={63} alt="" />
				</span>
				<h1>Hi, I'm Alfredo Navas.</h1>
			</div>

			<div class="hero-copy">
				<p>
					This is my <span style="color: var(--color-accent)">digital playground</span>, where WordPress, AI, web products, and <span style="color: var(--color-accent)">too many late-night ideas</span>	 turn into real things. Feel free to ask me anything.
				</p>
			</div>
		</section>
	</div>
</div>

<style>
	#container,
	.hero-shell {
		height: 100%;
	}

	#container {
		display: flex;
		flex-direction: column;
	}

	.hero-shell {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		min-height: clamp(16rem, 43vh, 26rem);
		padding: var(--space-6) var(--space-8) var(--space-2);
	}

	#hero {
		width: min(100%, 50rem);
		display: flex;
		flex-direction: column;
		color: var(--color-text);
	}

	.hero-title {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		min-height: 3.9375rem;
		padding-left: 1.0625rem;
	}

	.hero-skull-wrap {
		flex: 0 0 auto;
		display: inline-flex;
		animation: hero-skull-float 9.4s cubic-bezier(0.4, 0, 0.2, 1) 1.65s infinite;
		will-change: transform;
		transform: translate3d(0, 0, 0);
	}

	.hero-skull {
		flex: 0 0 auto;
		width: 3.9375rem;
		height: 3.9375rem;
		opacity: 0;
		transform: translate3d(0, 1rem, 0) scale(0.91);
		animation: hero-skull-enter 900ms cubic-bezier(0.22, 0.61, 0.36, 1) 680ms forwards;
		will-change: opacity, transform;
	}

	@keyframes hero-skull-enter {
		from {
			opacity: 0;
			transform: translate3d(0, 1rem, 0) scale(0.91);
		}

		62% {
			opacity: 1;
			transform: translate3d(0.04rem, -0.14rem, 0) scale(1.02);
		}

		to {
			opacity: 1;
			transform: translate3d(0, 0, 0) scale(1);
		}
	}

	@keyframes hero-skull-float {
		0% {
			transform: translate3d(-0.1rem, 0.44rem, 0) rotate(-0.8deg);
			opacity: 0.95;
		}

		36% {
			transform: translate3d(0.14rem, -0.28rem, 0) rotate(0.35deg);
			opacity: 1;
		}

		68% {
			transform: translate3d(0.08rem, 0.12rem, 0) rotate(0.85deg);
			opacity: 0.97;
		}

		100% {
			transform: translate3d(-0.1rem, 0.44rem, 0) rotate(-0.8deg);
			opacity: 0.95;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-skull-wrap,
		.hero-skull {
			animation: none;
			transform: none;
			opacity: 1;
		}
	}

	h1 {
		font-family: var(--font-family-sans);
		font-size: 2.25rem;
		line-height: 1.15;
		font-weight: 700;
	}

	.hero-copy {
		margin-top: 1.75rem;
		display: grid;
		row-gap: 0;
	}

	p {
		font-family: var(--font-family-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-base);
		font-weight: var(--font-weight-regular);
	}

	@media (max-width: 48rem) {
		.hero-shell {
			flex: 1;
			min-height: auto;
			padding: clamp(0.25rem, 2.6vw, 0.6rem) 0 0;
			align-items: center;
		}

		#hero {
			width: min(100%, 22rem);
			align-items: center;
			text-align: center;
		}

		.hero-title {
			flex-direction: column;
			align-items: center;
			gap: clamp(1rem, 5.5vw, 1.5rem);
			min-height: 0;
			padding-left: 0;
		}

		.hero-skull {
			width: clamp(3.5rem, 16vw, 4.4rem);
			height: clamp(3.5rem, 16vw, 4.4rem);
		}

		.hero-copy {
			margin-top: clamp(0.95rem, 5.2vw, 1.5rem);
			max-width: min(100%, 19.5rem);
		}

		h1 {
			max-width: 100%;
			font-size: clamp(1.82rem, 8vw, 2.08rem);
			line-height: 1.2;
			text-wrap: balance;
		}

		p {
			font-size: clamp(0.98rem, 3.95vw, 1.05rem);
			line-height: 1.5;
		}
	}
</style>
