---
import logo from '../assets/logo.svg';
---

<div id="container">
	<main>
		<section id="hero">
			<div class="hero-title">
				<img src={logo.src} width="63" height="63" alt="" aria-hidden="true" />
				<h1>Hi, I’m Alfredo Navas.</h1>
			</div>

			<div class="hero-copy">
				<p>Ask me anything about my work or projects.</p>
				<p class="muted">This site is powered by an AI agent.</p>
			</div>
		</section>
	</main>
</div>

<style>
	#container,
	main {
		height: 100%;
	}

	main {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		padding: var(--space-12) var(--space-8) 4.5rem;
	}

	#hero {
		width: min(100%, 50rem);
		display: flex;
		flex-direction: column;
		color: var(--color-text);
	}

	.hero-title {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		min-height: 3.9375rem;
		padding-left: 1.0625rem;
	}

	.hero-title img {
		flex: 0 0 auto;
		width: 3.9375rem;
		height: 3.9375rem;
	}

	h1 {
		font-family: var(--font-family-sans);
		font-size: 2.25rem;
		line-height: 1.15;
		font-weight: 700;
	}

	.hero-copy {
		margin-top: 2.5625rem;
		display: grid;
		row-gap: var(--space-4);
	}

	p {
		font-family: var(--font-family-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-base);
		font-weight: var(--font-weight-regular);
	}

	.muted {
		color: var(--color-text);
	}

	@media (max-width: 48rem) {
		main {
			padding: var(--space-8) var(--space-4) var(--space-8);
		}

		.hero-title {
			gap: var(--space-4);
			min-height: 3rem;
			padding-left: 0;
		}

		.hero-title img {
			width: 3rem;
			height: 3rem;
		}

		.hero-copy {
			margin-top: var(--space-6);
			row-gap: var(--space-4);
		}

		h1 {
			font-size: 1.75rem;
			line-height: 1.2;
		}
	}
</style>
