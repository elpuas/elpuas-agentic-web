---
import logo from '../assets/logo.svg';
---

<div id="container">
	<main>
		<section id="hero">
			<div class="hero-title">
				<img src={logo.src} width="63" height="63" alt="" aria-hidden="true" />
				<h1>Hi, I'm Alfredo Navas, Product Builder.</h1>
			</div>

			<div class="hero-copy">
				<p>
					Welcome to my personal website! Here, I share my journey as a product builder, insights on
					technology, and my passion for creating innovative solutions. Ask me anything about my work or
					projects.
				</p>
			</div>
		</section>
	</main>
</div>

<style>
	#container,
	main {
		height: 100%;
	}

	#container {
		display: flex;
		flex-direction: column;
	}

	main {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		min-height: clamp(20rem, 56vh, 36rem);
		padding: var(--space-12) var(--space-8) var(--space-8);
	}

	#hero {
		width: min(100%, 50rem);
		display: flex;
		flex-direction: column;
		color: var(--color-text);
	}

	.hero-title {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		min-height: 3.9375rem;
		padding-left: 1.0625rem;
	}

	.hero-title img {
		flex: 0 0 auto;
		width: 3.9375rem;
		height: 3.9375rem;
	}

	h1 {
		font-family: var(--font-family-sans);
		font-size: 2.25rem;
		line-height: 1.15;
		font-weight: 700;
	}

	.hero-copy {
		margin-top: 2.5625rem;
		display: grid;
		row-gap: 0;
	}

	p {
		font-family: var(--font-family-sans);
		font-size: var(--font-size-base);
		line-height: var(--line-height-base);
		font-weight: var(--font-weight-regular);
	}

	@media (max-width: 48rem) {
		main {
			flex: 1;
			min-height: auto;
			padding: 0;
			align-items: center;
		}

		#hero {
			width: min(100%, 22rem);
			align-items: center;
			text-align: center;
		}

		.hero-title {
			flex-direction: column;
			align-items: center;
			gap: clamp(1rem, 5.5vw, 1.5rem);
			min-height: 0;
			padding-left: 0;
		}

		.hero-title img {
			width: clamp(3.5rem, 16vw, 4.4rem);
			height: clamp(3.5rem, 16vw, 4.4rem);
		}

		.hero-copy {
			margin-top: clamp(0.95rem, 5.2vw, 1.5rem);
			max-width: min(100%, 19.5rem);
		}

		h1 {
			max-width: 11.5ch;
			font-size: clamp(1.82rem, 8vw, 2.08rem);
			line-height: 1.2;
			text-wrap: balance;
		}

		p {
			font-size: clamp(0.98rem, 3.95vw, 1.05rem);
			line-height: 1.5;
		}
	}
</style>
