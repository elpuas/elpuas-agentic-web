---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareArticleBar from '../../components/ShareArticleBar.astro';
import { getBlogExcerpt, getBlogFeaturedImage, getBlogPublishDate } from '../../lib/blog-metadata';
import { SITE_URL, toAbsoluteUrl } from '../../lib/site';
export const prerender = true;

/**
 * Generates static routes for all published blog posts.
 */
export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

	return posts.map((post) => ({
		params: { slug: post.data.slug },
		props: { post },
	}));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const { Content } = await render(post);
const allPublishedPosts = (await getCollection('blog')).filter((entry) => !entry.data.draft);

const heroImageModules = import.meta.glob('../../assets/blog/**/*.{avif,gif,jpeg,jpg,png,svg,webp}', {
	eager: true,
});

/**
 * Resolves a frontmatter hero image path into a public asset URL.
 *
 * Supports relative `../../assets/...` references and leaves absolute/remote
 * URLs untouched.
 */
const resolveHeroImageSrc = (path?: string): string | undefined => {
	if (!path) {
		return undefined;
	}

	const resolveModuleSrc = (assetPath: string): string | undefined => {
		const assetModule = heroImageModules[assetPath] as
			| { default?: { src?: string } }
			| undefined;

		return assetModule?.default?.src ?? undefined;
	};

	if (path.startsWith('../../assets/')) {
		const webpPath = path.replace(/\.(avif|gif|jpe?g|png|svg)$/i, '.webp');

		return resolveModuleSrc(webpPath) ?? resolveModuleSrc(path);
	}

	if (path.startsWith('/src/assets/')) {
		const relativeAssetPath = `../../assets/${path.replace('/src/assets/', '')}`;
		const webpPath = relativeAssetPath.replace(/\.(avif|gif|jpe?g|png|svg)$/i, '.webp');

		return resolveModuleSrc(webpPath) ?? resolveModuleSrc(relativeAssetPath);
	}

	return path;
};

const publishDate = getBlogPublishDate(post.data);
const excerpt = getBlogExcerpt(post.data);
const heroImageSrc = resolveHeroImageSrc(getBlogFeaturedImage(post.data));
const formattedDate = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' }).format(publishDate);
const siteUrl = Astro.site ?? new URL(SITE_URL);
const articleUrl = post.data.canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const articleImageUrl = heroImageSrc ? toAbsoluteUrl(heroImageSrc, siteUrl) : undefined;
const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.data.title,
	description: excerpt,
	datePublished: publishDate.toISOString(),
	dateModified: publishDate.toISOString(),
	author: {
		'@type': 'Person',
		name: post.data.author,
	},
	publisher: {
		'@type': 'Person',
		name: post.data.author,
	},
	mainEntityOfPage: articleUrl,
	articleSection: post.data.category,
	keywords: post.data.tags.join(', '),
	image: articleImageUrl,
};
const searchableContent = (value: string): Set<string> =>
	new Set(
		value
			.toLowerCase()
			.replace(/[^a-z0-9\s]/g, ' ')
			.split(/\s+/)
			.filter((token) => token.length >= 4),
	);
const currentTags = new Set(post.data.tags.map((tag) => tag.toLowerCase()));
const currentTerms = searchableContent(`${post.data.title} ${excerpt}`);
const relatedPosts = allPublishedPosts
	.filter((entry) => entry.data.slug !== post.data.slug)
	.map((entry) => {
		const entryExcerpt = getBlogExcerpt(entry.data);
		const entryTerms = searchableContent(`${entry.data.title} ${entryExcerpt}`);
		const sharedTags = entry.data.tags.filter((tag) => currentTags.has(tag.toLowerCase())).length;
		const sharedTerms = [...entryTerms].filter((term) => currentTerms.has(term)).length;
		const sameCategory = entry.data.category === post.data.category ? 1 : 0;
		const score = sharedTags * 6 + sharedTerms * 2 + sameCategory * 4;

		return { entry, entryExcerpt, score };
	})
	.sort((a, b) => b.score - a.score || getBlogPublishDate(b.entry.data).getTime() - getBlogPublishDate(a.entry.data).getTime())
	.slice(0, 3);
const pageContext = [
	'Current Page Type: Blog Post',
	`Current Blog Title: ${post.data.title}`,
	`Current Blog Slug: ${post.data.slug}`,
	`Current Blog Description: ${excerpt}`,
	`Current Blog Category: ${post.data.category}`,
	`Current Blog Tags: ${post.data.tags.join(', ') || 'None'}`,
	'Current Blog Content:',
	post.body,
].join('\n');
---

<BaseLayout
	title={post.data.title}
	description={excerpt}
	canonicalUrl={articleUrl}
	ogType="article"
	ogImage={heroImageSrc}
	activeNav="blog"
	pageContext={pageContext}
	contentLayout="edge"
	floatingCliDesktop={true}
	schema={articleSchema}
>
	<article class="blog-post">
		<header class:list={['blog-hero', !heroImageSrc && 'blog-hero-fallback']}>
			{heroImageSrc ? (
				<img
					class="blog-hero-media"
					src={heroImageSrc}
					alt={post.data.heroAlt || post.data.title}
					loading="eager"
					decoding="async"
				/>
			) : (
				<div class="blog-hero-media blog-hero-media-fallback" aria-hidden="true"></div>
			)}
			<div class="blog-hero-overlay" aria-hidden="true"></div>
			<div class="blog-hero-content">
				<p class="blog-category">{post.data.category}</p>
				<h1>{post.data.title}</h1>
				<p class="blog-date">
					<time datetime={publishDate.toISOString()}>{formattedDate}</time>
				</p>
			</div>
		</header>

		<div class="post-content">
			<Content components={{ h1: 'h2' }} />
		</div>
		{relatedPosts.length > 0 && (
			<section class="related-posts" aria-label="Related blog posts">
				<h2>Related Reads</h2>
				<ul>
					{relatedPosts.map(({ entry, entryExcerpt }) => (
						<li>
							<a href={`/blog/${entry.data.slug}/`}>
								<span class="related-post-title">{entry.data.title}</span>
								<span class="related-post-meta">{entry.data.category}</span>
								<span class="related-post-excerpt">{entryExcerpt}</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		)}
		<ShareArticleBar title={post.data.title} description={excerpt} url={articleUrl} />
	</article>
</BaseLayout>

<style>
	.blog-post {
		width: 100%;
		margin: 0;
		padding: 0 0 var(--space-6);
	}

	.blog-hero {
		position: relative;
		min-height: clamp(15rem, 52vw, 24rem);
		overflow: hidden;
		background: #141614;
	}

	.blog-hero-media {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.blog-hero-media-fallback {
		background:
			radial-gradient(circle at 22% 14%, rgba(216, 255, 0, 0.13), transparent 56%),
			radial-gradient(circle at 88% 84%, rgba(130, 147, 84, 0.14), transparent 52%),
			linear-gradient(138deg, #181c1a 0%, #111311 52%, #191c19 100%);
	}

	.blog-hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(8, 9, 8, 0.26) 8%, rgba(8, 9, 8, 0.78) 100%);
	}

	.blog-hero-content {
		position: relative;
		z-index: 1;
		padding: clamp(1.25rem, 3.8vw, 2.5rem);
		max-width: min(100%, 41rem);
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		justify-content: flex-end;
		min-height: inherit;
	}

	.blog-category {
		margin: 0;
		font-size: 1rem;
		line-height: 1.2;
		font-weight: 760;
		color: #f6f8ee;
	}

	.blog-hero h1 {
		margin: 0;
		font-size: clamp(1.65rem, 4vw, 3rem);
		line-height: 1.12;
		font-weight: 760;
		color: #fcfcf8;
		text-wrap: balance;
	}

	@supports ((-webkit-background-clip: text) or (background-clip: text)) {
		.blog-hero h1 {
			background: linear-gradient(102deg, #ffffff 20%, #f3ffe4 62%, var(--color-accent) 100%);
			-webkit-background-clip: text;
			background-clip: text;
			-webkit-text-fill-color: transparent;
			color: transparent;
		}
	}

	.blog-date {
		margin: 0;
		font-size: 1.05rem;
		line-height: 1.35;
		font-weight: 630;
		color: #f2f6e2;
	}

	.post-content {
		margin: var(--space-8) auto 0;
		width: min(100%, 50rem);
		padding: 0 clamp(1rem, 2.4vw, 2.5rem);
		font-size: clamp(1rem, 0.2vw + 0.98rem, 1.1rem);
		line-height: 1.9;
		color: #dddfe3;
	}

	.post-content :global(h2),
	.post-content :global(h3),
	.post-content :global(h4),
	.post-content :global(h5),
	.post-content :global(h6) {
		margin: 0;
		margin-top: var(--space-8);
		margin-bottom: var(--space-3);
		line-height: 1.25;
		letter-spacing: -0.01em;
		color: var(--color-accent);
	}

	.post-content :global(h2) {
		font-size: clamp(1.45rem, 2.6vw, 1.95rem);
		font-weight: 700;
	}

	.post-content :global(h3) {
		font-size: clamp(1.2rem, 2.2vw, 1.45rem);
		font-weight: 680;
	}

	.post-content :global(h4),
	.post-content :global(h5),
	.post-content :global(h6) {
		font-size: 1.08rem;
		font-weight: 640;
	}

	.post-content :global(p),
	.post-content :global(ul),
	.post-content :global(ol),
	.post-content :global(blockquote),
	.post-content :global(pre),
	.post-content :global(figure) {
		margin: 0;
	}

	.post-content :global(* + p),
	.post-content :global(* + ul),
	.post-content :global(* + ol),
	.post-content :global(* + blockquote),
	.post-content :global(* + pre),
	.post-content :global(* + figure) {
		margin-top: var(--space-4);
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		padding-left: 1.35rem;
	}

	.post-content :global(li + li) {
		margin-top: var(--space-2);
	}

	.post-content :global(strong) {
		font-weight: 660;
		color: #f4f6f8;
	}

	.post-content :global(h2 strong),
	.post-content :global(h3 strong),
	.post-content :global(h4 strong),
	.post-content :global(h5 strong),
	.post-content :global(h6 strong) {
		color: inherit;
	}

	.post-content :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-decoration-color: rgba(216, 255, 0, 0.62);
		text-underline-offset: 0.16em;
		transition:
			text-decoration-color 120ms ease,
			filter 120ms ease;
	}

	.post-content :global(a:hover),
	.post-content :global(a:focus-visible) {
		filter: brightness(1.08);
		text-decoration-color: currentColor;
	}

	.post-content :global(blockquote) {
		padding: var(--space-3) var(--space-4);
		border-left: 0.2rem solid rgba(216, 255, 0, 0.65);
		background: rgba(255, 255, 255, 0.02);
		color: #eceff2;
	}

	.post-content :global(code) {
		font-size: 0.95em;
		padding: 0.08em 0.38em;
		border-radius: var(--radius-sm);
		background: rgba(255, 255, 255, 0.08);
	}

	.post-content :global(pre) {
		padding: var(--space-4);
		border-radius: var(--radius-md);
		border: var(--space-px) solid var(--color-border);
		background: #151717;
		overflow-x: auto;
	}

	.post-content :global(pre code) {
		padding: 0;
		background: transparent;
	}

	.post-content :global(hr) {
		margin: var(--space-8) 0;
		border: 0;
		height: var(--space-px);
		background: var(--color-border);
	}

	.post-content :global(img) {
		border-radius: var(--radius-md);
	}

	.post-content :global(.astro-code) {
		margin-top: var(--space-4);
	}

	.related-posts {
		margin: var(--space-8) auto 0;
		width: min(100%, 50rem);
		padding: 0 clamp(1rem, 2.4vw, 2.5rem);
	}

	.related-posts h2 {
		margin: 0;
		font-size: 1.1rem;
		line-height: 1.2;
		font-weight: 700;
		color: var(--color-accent);
	}

	.related-posts ul {
		margin: var(--space-4) 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: var(--space-3);
	}

	.related-posts li {
		margin: 0;
	}

	.related-posts a {
		display: grid;
		gap: 0.3rem;
		padding: var(--space-4);
		border: var(--space-px) solid rgba(216, 255, 0, 0.2);
		border-radius: var(--radius-md);
		background: rgba(216, 255, 0, 0.04);
		text-decoration: none;
		transition:
			background-color 120ms ease,
			border-color 120ms ease;
	}

	.related-posts a:hover,
	.related-posts a:focus-visible {
		background: rgba(216, 255, 0, 0.1);
		border-color: rgba(216, 255, 0, 0.42);
		outline: none;
	}

	.related-post-title {
		font-size: 1rem;
		line-height: 1.4;
		font-weight: 650;
		color: #fbfdf4;
	}

	.related-post-meta {
		font-size: 0.8rem;
		line-height: 1.2;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: rgba(216, 255, 0, 0.9);
	}

	.related-post-excerpt {
		font-size: 0.94rem;
		line-height: 1.5;
		color: #d4d8dd;
	}

	/* Hide legacy markdown share block now replaced by ShareArticleBar component. */
	.post-content :global(h5:has(+ p + p:has(a[href*='twitter.com/intent/tweet']))) {
		display: none;
	}

	.post-content :global(h5:has(+ p + p:has(a[href*='twitter.com/intent/tweet'])) + p) {
		display: none;
	}

	.post-content :global(p:has(a[href*='twitter.com/intent/tweet'])) {
		display: none;
	}

	@media (max-width: 48rem) {
		.blog-hero {
			min-height: clamp(12rem, 54vw, 17rem);
		}

		.blog-hero-content {
			padding: clamp(1rem, 4.2vw, 1.6rem);
			max-width: 100%;
		}

		.blog-category {
			font-size: 0.95rem;
		}

		.blog-date {
			font-size: 0.96rem;
		}

		.post-content {
			margin-top: var(--space-6);
			width: min(100%, 46.5rem);
			padding: 0 clamp(0.95rem, 4vw, 1.5rem);
			line-height: 1.8;
		}

		.related-posts {
			width: min(100%, 46.5rem);
			padding: 0 clamp(0.95rem, 4vw, 1.5rem);
		}
	}

	@media (max-width: 32rem) {
		.blog-hero h1 {
			font-size: 1.55rem;
		}

		.post-content {
			font-size: 1rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.post-content :global(a) {
			transition: none;
		}
	}
</style>
