---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import logo from '../../assets/logo.svg';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogExcerpt, getBlogPublishDate } from '../../lib/blog-metadata';

const POSTS_PER_PAGE = 6;

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => getBlogPublishDate(b.data).getTime() - getBlogPublishDate(a.data).getTime());

const postPages = Array.from({ length: Math.ceil(posts.length / POSTS_PER_PAGE) }, (_, pageIndex) => {
	const start = pageIndex * POSTS_PER_PAGE;
	return posts.slice(start, start + POSTS_PER_PAGE);
});

const formatDate = (date: Date): string => new Intl.DateTimeFormat('en-US', { dateStyle: 'medium' }).format(date);
---

<BaseLayout
	title="Blog Archive"
	description="Browse Alfredo Navas' blog archive covering WordPress engineering, JavaScript development, AI-assisted workflows, and lessons from real client projects."
	ogTitle="Blog Archive - Alfredo Navas Engineering Articles"
	ogDescription="Read practical articles on WordPress, JavaScript, AI workflows, and product development from Alfredo Navas."
	activeNav="blog"
>
	<section class="blog">
		<header class="blog-title">
			<Image src={logo} width={63} height={63} alt="" aria-hidden="true" />
			<h1>Blog</h1>
		</header>

		<p class="blog-intro">
			Welcome to my blog. Explore my experiences as a developer, solving problems, facing
			challenges, and sharing what I’ve learned along the way.
		</p>

		{posts.length > 0 ? (
			<div
				class="posts-carousel"
				data-carousel
				data-total-pages={postPages.length}
				role="region"
				aria-label="Latest posts carousel"
				tabindex="0"
			>
				<button class="carousel-arrow carousel-arrow-prev" type="button" data-prev aria-label="Show newer posts">
					<span aria-hidden="true">←</span>
				</button>

				<div class="carousel-viewport" data-viewport>
					<div class="carousel-track" data-track>
						{postPages.map((pagePosts, pageIndex) => (
							<section
								class="carousel-page"
								data-page
								data-page-index={pageIndex}
								hidden={pageIndex !== 0}
								aria-label={`Posts page ${pageIndex + 1} of ${postPages.length}`}
							>
								<ul class="post-grid" role="list">
									{pagePosts.map((post) => {
										const publishDate = getBlogPublishDate(post.data);
										const excerpt = getBlogExcerpt(post.data);
										const label = post.data.category || post.data.tags[0] || 'General';
										const trimmedExcerpt = excerpt.length > 130 ? `${excerpt.slice(0, 127).trimEnd()}...` : excerpt;

										return (
											<li>
												<a class="post-card" href={`/blog/${post.data.slug}/`}>
													<div class="post-body">
														<p class="post-label">{label}</p>
														<h3>{post.data.title}</h3>
														<p class="post-excerpt">{trimmedExcerpt}</p>
														<p class="post-date">
															<time datetime={publishDate.toISOString()}>{formatDate(publishDate)}</time>
														</p>
													</div>
												</a>
											</li>
										);
									})}
								</ul>
							</section>
						))}
					</div>
				</div>

				<button class="carousel-arrow carousel-arrow-next" type="button" data-next aria-label="Show older posts">
					<span aria-hidden="true">→</span>
				</button>

				<div class="carousel-dots" data-dots aria-label="Carousel pagination"></div>
			</div>
		) : (
			<p class="blog-empty">No posts published yet.</p>
		)}
	</section>
</BaseLayout>

<script>
	const carousel = document.querySelector('[data-carousel]');

	if (carousel instanceof HTMLElement) {
		const track = carousel.querySelector('[data-track]');
		const prevButton = carousel.querySelector('[data-prev]');
		const nextButton = carousel.querySelector('[data-next]');
		const dotsRoot = carousel.querySelector('[data-dots]');
		const pageElements = Array.from(carousel.querySelectorAll('[data-page]'));
		const totalPages = Number.parseInt(carousel.dataset.totalPages ?? '1', 10);
		let activePage = 0;

		if (
			track instanceof HTMLElement &&
			prevButton instanceof HTMLButtonElement &&
			nextButton instanceof HTMLButtonElement &&
			dotsRoot instanceof HTMLElement
		) {
			const dots = Array.from({ length: totalPages }, (_, index) => {
				const dot = document.createElement('button');
				dot.type = 'button';
				dot.className = 'carousel-dot';
				dot.setAttribute('aria-label', `Go to page ${index + 1}`);
				dot.dataset.index = String(index);
				dotsRoot.append(dot);
				return dot;
			});

			const render = () => {
				prevButton.disabled = activePage === 0;
				nextButton.disabled = activePage === totalPages - 1;

				dots.forEach((dot, index) => {
					const isActive = index === activePage;
					dot.classList.toggle('is-active', isActive);
					dot.setAttribute('aria-current', isActive ? 'true' : 'false');
				});

				pageElements.forEach((page, index) => {
					const isActive = index === activePage;
					page.hidden = !isActive;
					page.setAttribute('aria-hidden', isActive ? 'false' : 'true');
				});
			};

			const goTo = (index) => {
				activePage = Math.max(0, Math.min(totalPages - 1, index));
				render();
			};

			prevButton.addEventListener('click', () => goTo(activePage - 1));
			nextButton.addEventListener('click', () => goTo(activePage + 1));

			dots.forEach((dot, index) => {
				dot.addEventListener('click', () => goTo(index));
			});

			carousel.addEventListener('keydown', (event) => {
				if (event.key === 'ArrowLeft') {
					event.preventDefault();
					goTo(activePage - 1);
				}

				if (event.key === 'ArrowRight') {
					event.preventDefault();
					goTo(activePage + 1);
				}
			});

			render();
		}
	}
</script>

<style>
	.blog {
		width: min(100%, 56rem);
		margin: 0 auto;
		color: var(--color-text);
		padding: var(--space-12) 0 var(--space-8);
	}

	.blog-title {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.blog-title img {
		width: 3.9375rem;
		height: 3.9375rem;
		flex: 0 0 auto;
	}

	.blog-title h1 {
		margin: 0;
		font-size: 2.25rem;
		line-height: 1.15;
		font-weight: 700;
	}

	.blog-intro {
		margin-top: var(--space-4);
		font-size: var(--font-size-base);
		line-height: var(--line-height-base);
		max-width: 62ch;
		color: color-mix(in srgb, var(--color-text) 90%, white 10%);
	}

	.posts-carousel {
		--neon-accent: #ccff0a;
		--card-bg: rgba(11, 14, 18, 0.74);
		position: relative;
		margin-top: var(--space-6);
		padding: 0 0 2.5rem;
	}

	.carousel-viewport {
		overflow: visible;
	}

	.carousel-track {
		position: relative;
	}

	.carousel-page {
		width: 100%;
		animation: page-enter 220ms ease;
	}

	.post-grid {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.post-card {
		display: block;
		padding: 0.95rem 1.05rem;
		min-height: 9.75rem;
		border-radius: 0.85rem;
		background: var(--card-bg);
		text-decoration: none;
		color: inherit;
		transition:
			transform 140ms ease,
			box-shadow 160ms ease,
			background-color 160ms ease;
	}

	.post-card:hover,
	.post-card:focus-visible {
		transform: translateY(-2px);
		box-shadow: 0 8px 18px rgba(0, 0, 0, 0.3);
		background: rgba(16, 21, 27, 0.94);
		outline: none;
	}

	.post-body {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		min-width: 0;
	}

	.post-label {
		margin: 0;
		font-size: 0.76rem;
		line-height: 1.2;
		font-weight: 620;
		color: #d6ff47;
	}

	.post-card h3 {
		margin: 0;
		font-size: 1.26rem;
		line-height: 1.18;
		font-weight: 640;
		color: #f8fbff;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		text-wrap: balance;
	}

	.post-excerpt {
		margin: 0;
		font-size: 0.92rem;
		line-height: 1.4;
		color: rgba(224, 232, 241, 0.82);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-date {
		margin: auto 0 0;
		font-size: 0.86rem;
		line-height: 1.2;
		color: rgba(214, 222, 233, 0.78);
	}

	.carousel-arrow {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		width: 2.85rem;
		height: 2.85rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		border-radius: 0.85rem;
		border: 1px solid rgba(204, 255, 10, 0.28);
		background: rgba(8, 12, 18, 0.92);
		color: #d6ff3f;
		font-size: 1.45rem;
		line-height: 1;
		cursor: pointer;
		transition:
			border-color 130ms ease,
			color 130ms ease,
			background-color 130ms ease,
			transform 130ms ease;
	}

	.carousel-arrow:hover,
	.carousel-arrow:focus-visible {
		border-color: rgba(204, 255, 10, 0.72);
		background: rgba(13, 20, 28, 0.98);
		color: #ebff9f;
		outline: none;
	}

	.carousel-arrow:focus-visible {
		box-shadow: 0 0 0 2px rgba(204, 255, 10, 0.3);
	}

	.carousel-arrow[disabled] {
		opacity: 0.42;
		cursor: not-allowed;
	}

	.carousel-arrow-prev {
		left: -2.8rem;
	}

	.carousel-arrow-next {
		right: -2.8rem;
	}

	.carousel-dots {
		position: absolute;
		left: 50%;
		bottom: 1.05rem;
		transform: translateX(-50%);
		display: inline-flex;
		align-items: center;
		gap: 0.58rem;
	}

	.carousel-dot {
		width: 0.62rem;
		height: 0.62rem;
		border-radius: 50%;
		padding: 0;
		border: none;
		background: rgba(212, 219, 228, 0.4);
		cursor: pointer;
		transition:
			transform 130ms ease,
			background-color 130ms ease;
	}

	.carousel-dot:hover,
	.carousel-dot:focus-visible {
		background: rgba(238, 244, 251, 0.8);
		outline: none;
	}

	.carousel-dot.is-active {
		background: var(--neon-accent);
		transform: scale(1.14);
	}

	@keyframes page-enter {
		from {
			opacity: 0.88;
			transform: translateY(4px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.blog-empty {
		margin-top: var(--space-6);
		color: var(--color-text-muted);
	}

	@media (max-width: 64rem) {
		.post-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 48rem) {
		.blog {
			padding: var(--space-8) 0 var(--space-6);
		}

		.blog-title {
			gap: var(--space-4);
		}

		.blog-title img {
			width: 3rem;
			height: 3rem;
		}

		.blog-title h1 {
			font-size: 1.75rem;
			line-height: 1.2;
		}

		.latest-heading {
			margin-top: var(--space-6);
		}

		.posts-carousel {
			padding: 0 0 4rem;
		}

		.post-grid {
			grid-template-columns: 1fr;
		}

		.post-card {
			min-height: 8.75rem;
		}

		.carousel-arrow {
			top: auto;
			bottom: 0.65rem;
			transform: none;
			width: 2.55rem;
			height: 2.55rem;
			font-size: 1.28rem;
		}

		.carousel-arrow-prev {
			left: 0;
		}

		.carousel-arrow-next {
			right: 0;
		}

		.carousel-dots {
			bottom: 1.42rem;
		}
	}
</style>
