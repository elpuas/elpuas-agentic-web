---
import '../styles/global.css';
import ProfilePanel from '../components/ProfilePanel.astro';

const {
	title = 'Alfredo Navas',
	description = 'Alfredo Navas personal website.',
	activeNav = 'home',
	pageContext = '',
} = Astro.props;
const currentPage = Astro.url.pathname;

const navigation = [
	{ href: '/', label: 'Home', key: 'home' },
	{ href: '/about/', label: 'About', key: 'about' },
	{ href: '/blog/', label: 'Blog', key: 'blog' },
	{ href: '/contact/', label: 'Contact', key: 'contact' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
		<body>
			<div
				class="shell"
				data-sidebar-shell
				data-sidebar-open="false"
				data-home={currentPage === '/' ? 'true' : 'false'}
			>
				<button
					class="sidebar-toggle"
					type="button"
					aria-label="Open navigation menu"
					aria-controls="primary-sidebar"
					aria-expanded="false"
					data-sidebar-toggle
				>
					<span class="sidebar-toggle-line" aria-hidden="true"></span>
					<span class="sidebar-toggle-line" aria-hidden="true"></span>
					<span class="sidebar-toggle-line" aria-hidden="true"></span>
				</button>

				<aside class="sidebar" id="primary-sidebar" aria-label="Primary navigation" data-mobile-sidebar>
					<div class="search-wrap">
						<svg class="search-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path
								d="m21 21-4.2-4.2m1.2-5.3a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</svg>
						<input type="text" value="" placeholder="Search" aria-label="Search" readonly />
					</div>

					<nav class="sidebar-nav">
						<ul class="nav-list">
							{navigation.map((item) => (
								<li class="nav-item">
									<a
										class="nav-link"
									href={item.href}
										aria-current={activeNav === item.key ? 'page' : undefined}
									>
										<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
											<use href={`#icon-${item.key}`} />
										</svg>
										<span>{item.label}</span>
									</a>
								</li>
							))}
						</ul>
					</nav>

					<ProfilePanel />
				</aside>

				<button class="sidebar-backdrop" type="button" aria-hidden="true" tabindex="-1" data-sidebar-backdrop></button>

				<div class="workspace">
					<main class="content">
						<div class="content-inner">
							<slot />
						</div>
					</main>

					<section
						class="cli"
						aria-label="Command line interface"
						data-page={currentPage}
						data-page-context={encodeURIComponent(pageContext)}
					>
						<div class="cli-panel">
							<div class="cli-box">
								<div class="cli-messages" id="cli-messages"></div>
								<form class="cli-row" id="cli-form">
									<button class="cli-btn" type="button" aria-label="New command" disabled>
										<svg viewBox="0 0 24 24" aria-hidden="true">
											<path
												d="M12 5v14M5 12h14"
												fill="none"
												stroke="currentColor"
												stroke-linecap="round"
												stroke-width="1.8"
											/>
										</svg>
									</button>
									<input
										class="cli-input"
										id="cli-input"
										name="question"
										type="text"
										placeholder="Ask me anything..."
										aria-label="Ask me anything"
										autocomplete="off"
										required
									/>
									<div class="cli-actions">
										<button class="cli-btn" type="button" aria-label="Web" disabled>
											<svg viewBox="0 0 24 24">
												<use href="#icon-web" />
											</svg>
										</button>
										<button class="cli-btn" type="button" aria-label="Mic" disabled>
											<svg viewBox="0 0 24 24">
												<use href="#icon-mic" />
											</svg>
										</button>
										<button class="cli-btn cli-btn-send" type="submit" aria-label="Send">
											<svg viewBox="0 0 24 24">
												<use href="#icon-send" />
											</svg>
										</button>
									</div>
								</form>
							</div>
							<p class="cli-hint">
								Try: <span>about</span>, <span>projects</span>, <span>experience</span>
							</p>
						</div>
					</section>
				</div>

				<svg class="icon-defs" aria-hidden="true" focusable="false">
					<defs>
						<symbol id="icon-home" viewBox="0 0 24 24">
							<path
								d="M4 11.2 12 5l8 6.2V20a1 1 0 0 1-1 1h-4.5v-5h-5v5H5a1 1 0 0 1-1-1v-8.8Z"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-about" viewBox="0 0 24 24">
							<path
								d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-projects" viewBox="0 0 24 24">
							<path
								d="M8 4h8l4 4v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h3Zm4 0v4h4"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-blog" viewBox="0 0 24 24">
							<path
								d="M7 3h8l5 5v13H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm8 0v5h5M9 13h6M9 17h6"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-contact" viewBox="0 0 24 24">
							<path
								d="M4 6h16v12H4zM4 7l8 6 8-6"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-web" viewBox="0 0 24 24">
							<path
								d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18M4.8 7.5h14.4M4.8 16.5h14.4"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-mic" viewBox="0 0 24 24">
							<path
								d="M12 3a3 3 0 0 1 3 3v6a3 3 0 1 1-6 0V6a3 3 0 0 1 3-3Zm0 14v4m-5-7a5 5 0 0 0 10 0"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-send" viewBox="0 0 24 24">
							<path
								d="m12 5 7 7m-7-7-7 7m7-7v14"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
					</defs>
				</svg>
			</div>
			<script>
				const form = document.querySelector('#cli-form');
				const input = document.querySelector('#cli-input');
				const messages = document.querySelector('#cli-messages');
				const cliRoot = document.querySelector('.cli');
				const page = cliRoot?.dataset.page ?? '/';
				const encodedPageContext = cliRoot?.dataset.pageContext ?? '';
				let pageContext = '';

				if (encodedPageContext) {
					try {
						pageContext = decodeURIComponent(encodedPageContext);
					} catch {
						pageContext = '';
					}
				}

				const submitButton = form?.querySelector('.cli-btn-send');

				if (form && input && messages && submitButton) {
					const assistantLinkPattern =
						/(https?:\/\/[^\s<>"']+)|(\/[a-zA-Z0-9][a-zA-Z0-9/_-]*)/g;
					const trailingPunctuationPattern = /[.,!?;:)\]]+$/;

					const appendAssistantTextWithLinks = (container, paragraph) => {
						let lastIndex = 0;

						for (const match of paragraph.matchAll(assistantLinkPattern)) {
							const index = match.index ?? 0;
							const rawLink = match[0];

							if (index > lastIndex) {
								container.append(document.createTextNode(paragraph.slice(lastIndex, index)));
							}

							let href = rawLink;
							let trailing = '';
							const trailingMatch = rawLink.match(trailingPunctuationPattern);

							if (trailingMatch) {
								trailing = trailingMatch[0];
								href = rawLink.slice(0, -trailing.length);
							}

							if (href) {
								const link = document.createElement('a');
								link.href = href;
								if (href.startsWith('http://') || href.startsWith('https://')) {
									link.target = '_blank';
									link.rel = 'noopener noreferrer';
								}
								link.textContent = href;
								container.append(link);
							}

							if (trailing) {
								container.append(document.createTextNode(trailing));
							}

							lastIndex = index + rawLink.length;
						}

						if (lastIndex < paragraph.length) {
							container.append(document.createTextNode(paragraph.slice(lastIndex)));
						}
					};

					const scrollMessages = () => {
						messages.scrollTop = messages.scrollHeight;
					};

					const renderMessageContent = (item, role, text, isLoading = false) => {
						item.replaceChildren();

						if (isLoading) {
							const loader = document.createElement('span');
							loader.className = 'cli-loader';
							loader.setAttribute('aria-label', 'Assistant is typing');

							for (let i = 0; i < 3; i += 1) {
								const dot = document.createElement('span');
								dot.className = 'cli-loader-dot';
								loader.append(dot);
							}

							item.append(loader);
							return;
						}

						const value = typeof text === 'string' ? text.trim() : '';
						const paragraphs =
							role === 'assistant'
								? value.split(/\n+/).map((paragraph) => paragraph.trim()).filter(Boolean)
								: [value];

						paragraphs.forEach((paragraph) => {
							const block = document.createElement('p');
							block.className = 'cli-message-paragraph';

							if (role === 'assistant') {
								appendAssistantTextWithLinks(block, paragraph);
							} else {
								block.textContent = paragraph;
							}

							item.append(block);
						});
					};

					const appendMessage = (role, text, isLoading = false) => {
						const item = document.createElement('div');
						item.className = `cli-message cli-message-${role}`;
						renderMessageContent(item, role, text, isLoading);
						messages.append(item);
						scrollMessages();
						return item;
					};

					form.addEventListener('submit', async (event) => {
						event.preventDefault();
						const question = input.value.trim();

						if (!question) {
							return;
						}

						appendMessage('user', question);
						const assistantMessage = appendMessage('assistant', '', true);
						input.value = '';
						input.disabled = true;
						submitButton.disabled = true;

						try {
							const requestBody = pageContext ? { question, page, pageContext } : { question, page };
							if (import.meta.env.DEV) {
								console.debug('[cli] /api/ask payload', {
									question,
									page,
									pageContextPreview: pageContext.slice(0, 240),
								});
							}

							const response = await fetch('/api/ask', {
								method: 'POST',
								headers: { 'Content-Type': 'application/json' },
								body: JSON.stringify(requestBody),
							});
							const payload = await response.json();
							const text = typeof payload.text === 'string' ? payload.text : "I don't know.";
							renderMessageContent(assistantMessage, 'assistant', text);
							scrollMessages();
						} catch {
							renderMessageContent(assistantMessage, 'assistant', 'Something went wrong. Please try again.');
							scrollMessages();
						} finally {
							input.disabled = false;
							submitButton.disabled = false;
							input.focus();
						}
					});
				}

				const sidebarRoots = document.querySelectorAll('[data-sidebar-shell]');
				const mobileSidebarQuery = window.matchMedia('(max-width: 48rem)');

				sidebarRoots.forEach((root) => {
					if (root.dataset.sidebarBound === 'true') {
						return;
					}

					root.dataset.sidebarBound = 'true';
					const sidebar = root.querySelector('[data-mobile-sidebar]');
					const toggle = root.querySelector('[data-sidebar-toggle]');
					const backdrop = root.querySelector('[data-sidebar-backdrop]');
					const navLinks = root.querySelectorAll('.nav-link');

					if (!(sidebar instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) {
						return;
					}

					const syncSidebarState = (open) => {
						const isMobile = mobileSidebarQuery.matches;
						root.dataset.sidebarOpen = open ? 'true' : 'false';
						toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
						toggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');

						if (!isMobile) {
							sidebar.setAttribute('aria-hidden', 'false');
							sidebar.removeAttribute('inert');
							document.body.style.removeProperty('overflow');
							return;
						}

						sidebar.setAttribute('aria-hidden', open ? 'false' : 'true');
						if (open) {
							sidebar.removeAttribute('inert');
							document.body.style.overflow = 'hidden';
						} else {
							sidebar.setAttribute('inert', '');
							document.body.style.removeProperty('overflow');
						}
					};

					const closeSidebar = () => {
						syncSidebarState(false);
					};

					toggle.addEventListener('click', () => {
						const nextOpen = root.dataset.sidebarOpen !== 'true';
						syncSidebarState(nextOpen);
					});

					backdrop?.addEventListener('click', closeSidebar);

					navLinks.forEach((link) => {
						link.addEventListener('click', () => {
							if (mobileSidebarQuery.matches) {
								closeSidebar();
							}
						});
					});

					document.addEventListener('pointerdown', (event) => {
						if (!mobileSidebarQuery.matches || root.dataset.sidebarOpen !== 'true') {
							return;
						}

						if (sidebar.contains(event.target) || toggle.contains(event.target)) {
							return;
						}

						closeSidebar();
					});

					document.addEventListener('keydown', (event) => {
						if (event.key === 'Escape' && root.dataset.sidebarOpen === 'true') {
							closeSidebar();
							toggle.focus();
						}
					});

					mobileSidebarQuery.addEventListener('change', () => {
						syncSidebarState(false);
					});

					syncSidebarState(false);
				});
			</script>
		</body>
</html>

<style>
	.shell {
		min-height: 100vh;
		display: grid;
		grid-template-columns: 16rem minmax(0, 1fr);
		background: var(--color-canvas);
	}

	.sidebar-toggle {
		display: none;
	}

	.sidebar-backdrop {
		display: none;
	}

	.sidebar {
		display: flex;
		flex-direction: column;
		position: sticky;
		top: 0;
		height: 100vh;
		overflow-y: auto;
		background: var(--color-surface);
		border-right: var(--space-px) solid var(--color-border);
		padding-top: var(--space-4);
		min-width: 0;
		font-family: var(--font-family-sans);
	}

	.search-wrap {
		position: relative;
		margin: 0 var(--space-4);
	}

	.search-wrap input {
		width: 100%;
		height: 2.375rem;
		border-radius: var(--radius-lg);
		border: var(--space-px) solid var(--color-border);
		background: var(--color-canvas);
		padding: var(--space-2) var(--space-3) var(--space-2) 2.25rem;
		color: var(--color-text-placeholder);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-sm);
		letter-spacing: 0;
	}

	.search-wrap input::placeholder {
		color: var(--color-text-placeholder);
	}

	.search-icon {
		position: absolute;
		top: 0.6875rem;
		left: 0.75rem;
		width: 1rem;
		height: 1rem;
		color: var(--color-text-placeholder);
		pointer-events: none;
	}

	.sidebar-nav {
		margin-top: var(--space-4);
		padding: 0 var(--space-3);
	}

	.nav-list {
		display: grid;
		gap: 0;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.nav-link {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		height: 2.5rem;
		padding: var(--space-2) var(--space-3);
		border-radius: var(--radius-lg);
		color: var(--color-text-muted);
		font-size: var(--font-size-sm);
		line-height: 1.25rem;
		font-weight: var(--font-weight-medium);
		transition:
			color 120ms ease,
			background-color 120ms ease;
	}

	.nav-icon {
		width: 1rem;
		height: 1rem;
		flex: 0 0 auto;
	}

	.nav-link:hover,
	.nav-link:focus-visible {
		color: var(--color-text);
		background: rgba(255, 255, 255, 0.03);
		outline: none;
	}

	.nav-link[aria-current='page'] {
		color: var(--color-accent);
		background: var(--color-accent-soft);
	}

	.workspace {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.content {
		flex: 1;
		padding: var(--space-8) var(--space-8) var(--space-12);
	}

	.content-inner {
		width: min(100%, 64rem);
		margin: 0 auto;
	}

	.cli {
		padding: 0 var(--space-8) var(--space-24);
		font-family: var(--font-family-sans);
	}

	.cli-panel {
		width: min(100%, 56rem);
		margin: 0 auto;
	}

	.cli-box {
		background: var(--color-surface);
		border: var(--space-px) solid var(--color-border);
		border-radius: 1rem;
		padding: var(--space-px);
		box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);
	}

	.cli-messages {
		max-height: 13rem;
		overflow: auto;
		padding: var(--space-4);
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.cli-message {
		margin: 0;
		max-width: min(100%, 44rem);
		padding: var(--space-3) var(--space-4);
		border-radius: var(--radius-lg);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-base);
		border: var(--space-px) solid transparent;
		background: rgba(255, 255, 255, 0.02);
	}

	.cli-message-paragraph {
		margin: 0;
	}

	.cli-message-paragraph + .cli-message-paragraph {
		margin-top: var(--space-3);
	}

	.cli-message-user {
		color: var(--color-accent);
		background: var(--color-accent-soft);
		border-color: rgba(216, 255, 0, 0.2);
	}

	.cli-message-assistant {
		color: var(--color-text-subtle);
		border-color: var(--color-border);
	}

	:global(.cli-message-assistant a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-decoration-color: rgba(216, 255, 0, 0.55);
		text-underline-offset: 0.14em;
		transition:
			filter 120ms ease,
			text-decoration-color 120ms ease;
	}

	:global(.cli-message-assistant a:hover),
	:global(.cli-message-assistant a:focus-visible) {
		filter: brightness(1.12);
		text-decoration-color: currentColor;
	}

	:global(.cli-loader) {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		min-height: 1rem;
		color: var(--color-accent);
	}

	:global(.cli-loader-dot) {
		width: 0.35rem;
		height: 0.35rem;
		border-radius: 999px;
		background: currentColor;
		opacity: 0.35;
		animation: cli-loader-pulse 1s ease-in-out infinite;
	}

	:global(.cli-loader-dot:nth-child(2)) {
		animation-delay: 0.15s;
	}

	:global(.cli-loader-dot:nth-child(3)) {
		animation-delay: 0.3s;
	}

	@keyframes cli-loader-pulse {
		0%,
		80%,
		100% {
			opacity: 0.35;
			transform: translateY(0);
		}

		40% {
			opacity: 1;
			transform: translateY(-0.1rem);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		:global(.cli-loader-dot) {
			animation: none;
			opacity: 0.6;
		}
	}

	.cli-row {
		height: 3.75rem;
		display: flex;
		align-items: center;
		gap: var(--space-3);
		padding: var(--space-3) var(--space-4);
	}

	.cli-btn {
		width: 2.25rem;
		height: 2.25rem;
		border-radius: var(--radius-lg);
		color: var(--color-text-muted);
		display: grid;
		place-items: center;
	}

	.cli-btn svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	.cli-btn:disabled {
		cursor: default;
	}

	.cli-input {
		flex: 1 1 auto;
		min-width: 0;
		color: var(--color-text);
		font-size: var(--font-size-base);
		line-height: var(--line-height-base);
		background: transparent;
		border: 0;
		padding: 0;
	}

	.cli-input::placeholder {
		color: var(--color-text-placeholder);
	}

	.cli-input:focus {
		outline: none;
	}

	.cli-input:disabled {
		opacity: 0.65;
	}

	.cli-actions {
		display: flex;
		align-items: center;
		gap: var(--space-2);
	}

