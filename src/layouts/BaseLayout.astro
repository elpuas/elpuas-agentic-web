---
import '../styles/global.css';

const {
	title = 'Alfredo Navas',
	description = 'Alfredo Navas personal website.',
	activeNav = 'home',
} = Astro.props;

const navigation = [
	{ href: '/', label: 'Home', key: 'home' },
	{ href: '/about/', label: 'About', key: 'about' },
	{ href: '/projects/', label: 'Projects', key: 'projects' },
	{ href: '/blog/', label: 'Blog', key: 'blog' },
	{ href: '/contact/', label: 'Contact', key: 'contact' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body>
		<div class="shell">
			<aside class="sidebar" aria-label="Primary navigation">
				<a class="brand" href="/">Alfredo Navas</a>

				<nav>
					<ul class="nav-list">
						{navigation.map((item) => (
							<li class="nav-item">
								<a
									class="nav-link"
									href={item.href}
									aria-current={activeNav === item.key ? 'page' : undefined}
								>
									{item.label}
								</a>
							</li>
						))}
					</ul>
				</nav>
			</aside>

			<div class="workspace">
				<main class="content">
					<slot />
				</main>

				<section class="cli" aria-label="Command line interface" />
			</div>
		</div>
	</body>
</html>

<style>
	.shell {
		min-height: 100vh;
		display: grid;
		grid-template-columns: 16rem minmax(0, 1fr);
		background: var(--color-canvas);
	}

	.sidebar {
		display: flex;
		flex-direction: column;
		gap: var(--space-8);
		padding: var(--space-8);
		border-right: var(--space-px) solid var(--color-border);
		background: var(--color-surface);
	}

	.brand {
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text);
	}

	.nav-list {
		display: grid;
		gap: var(--space-2);
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.nav-link {
		display: block;
		padding: var(--space-3) var(--space-4);
		border-radius: var(--radius-md);
		color: var(--color-text-muted);
		transition:
			color 120ms ease,
			background-color 120ms ease;
	}

	.nav-link:hover,
	.nav-link:focus-visible {
		color: var(--color-text);
		background: rgba(255, 255, 255, 0.03);
	}

	.nav-link[aria-current='page'] {
		color: var(--color-text);
		background: var(--color-accent-soft);
	}

	.workspace {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.content {
		flex: 1;
		padding: clamp(var(--space-4), 4vw, var(--space-8));
	}

	.cli {
		min-height: 4.5rem;
		border-top: var(--space-px) solid var(--color-border);
		background: rgba(255, 255, 255, 0.02);
	}

	@media (max-width: 48rem) {
		.shell {
			grid-template-columns: 1fr;
		}

		.sidebar {
			border-right: 0;
			border-bottom: var(--space-px) solid var(--color-border);
		}
	}
</style>
