---
import { Image } from 'astro:assets';
import '../styles/global.css';
import ProfilePanel from '../components/ProfilePanel.astro';
import logo from '../assets/logo.svg';
import { buildSearchIndex } from '../lib/search-index';
import {
	DEFAULT_DESCRIPTION,
	DEFAULT_OG_IMAGE,
	DEFAULT_TITLE,
	SITE_NAME,
	SITE_URL,
	resolveCanonicalUrl,
	toAbsoluteUrl,
} from '../lib/site';

const {
	title = DEFAULT_TITLE,
	description = DEFAULT_DESCRIPTION,
	ogTitle,
	ogDescription,
	activeNav = 'home',
	pageContext = '',
	contentLayout = 'default',
	floatingCliDesktop = true,
	showCli = true,
	canonicalUrl,
	ogImage = DEFAULT_OG_IMAGE,
	ogType = 'website',
	twitterCard = 'summary_large_image',
	schema,
	noindex = false,
} = Astro.props;
const currentPage = Astro.url.pathname;
const isEdgeContentLayout = contentLayout === 'edge';
const pageTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;
const socialTitle = ogTitle ?? pageTitle;
const socialDescription = ogDescription ?? description;
const siteUrl = Astro.site ?? new URL(SITE_URL);
const canonical = resolveCanonicalUrl({
	canonicalUrl,
	pathname: currentPage,
	siteUrl,
});
const ogImageAbsolute = toAbsoluteUrl(ogImage, siteUrl);
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim();
const searchIndex = await buildSearchIndex();

const defaultSchemas: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		name: 'Alfredo Navas',
		url: siteUrl.toString(),
		jobTitle: 'Senior WordPress & Full Stack Developer',
		email: 'mailto:elpuas@gmail.com',
		description:
			'Senior WordPress and full stack developer focused on web platforms, AI workflows, and practical product delivery.',
		knowsAbout: [
			'WordPress',
			'JavaScript',
			'TypeScript',
			'Astro',
			'AI Engineering',
			'Web Performance',
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_NAME,
		url: siteUrl.toString(),
		description: DEFAULT_DESCRIPTION,
		inLanguage: 'en',
		publisher: {
			'@type': 'Person',
			name: 'Alfredo Navas',
		},
	},
];

const customSchemas = Array.isArray(schema)
	? (schema as Array<Record<string, unknown>>)
	: schema
		? [schema as Record<string, unknown>]
		: [];
const pageSchemas = [...defaultSchemas, ...customSchemas];

const navigation = [
	{ href: '/', label: 'Home', key: 'home' },
	{ href: '/about/', label: 'About', key: 'about' },
	{ href: '/blog/', label: 'Blog', key: 'blog' },
	{ href: '/contact/', label: 'Contact', key: 'contact' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={robotsContent} />
		<link rel="canonical" href={canonical} />

		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={socialTitle} />
		<meta property="og:description" content={socialDescription} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageAbsolute} />

		<meta name="twitter:card" content={twitterCard} />
		<meta name="twitter:title" content={socialTitle} />
		<meta name="twitter:description" content={socialDescription} />
		<meta name="twitter:image" content={ogImageAbsolute} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{pageTitle}</title>

		{pageSchemas.map((schemaNode) => (
			<script type="application/ld+json" set:html={JSON.stringify(schemaNode)} />
		))}

		{gaMeasurementId && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
				<script is:inline define:vars={{ gaMeasurementId }}>
					window.dataLayer = window.dataLayer || [];
					function gtag() {
						dataLayer.push(arguments);
					}
					gtag('js', new Date());
					gtag('config', gaMeasurementId);
				</script>
			</>
		)}
	</head>
		<body>
			<div
				class:list={[
					'shell',
					showCli && floatingCliDesktop && 'shell-cli-floating-desktop',
					!showCli && 'shell-no-cli',
				]}
				data-sidebar-shell
				data-sidebar-open="false"
				data-cli-expanded="false"
				data-home={currentPage === '/' ? 'true' : 'false'}
			>
				<aside class="sidebar" id="primary-sidebar" aria-label="Primary navigation" data-mobile-sidebar>
					<div class="search-wrap">
						<svg class="search-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path
								d="m21 21-4.2-4.2m1.2-5.3a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</svg>
						<input
							type="text"
							value=""
							placeholder="Search"
							aria-label="Search content"
							autocomplete="off"
							spellcheck="false"
							data-sidebar-search-input
						/>
						<div class="search-dropdown" data-sidebar-search-dropdown hidden>
							<ul class="search-results" data-sidebar-search-results></ul>
						</div>
						<script type="application/json" id="sidebar-search-index" set:html={JSON.stringify(searchIndex)} />
					</div>

					<nav class="sidebar-nav">
						<ul class="nav-list">
							{navigation.map((item) => (
								<li class="nav-item">
									<a
										class="nav-link"
									href={item.href}
										aria-current={activeNav === item.key ? 'page' : undefined}
									>
										<svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
											<use href={`#icon-${item.key}`} />
										</svg>
										<span>{item.label}</span>
									</a>
								</li>
							))}
						</ul>
					</nav>

					<ProfilePanel />
				</aside>

				<button class="sidebar-backdrop" type="button" aria-hidden="true" tabindex="-1" data-sidebar-backdrop></button>

				<div class="workspace">
					<header class="mobile-header" aria-label="Mobile header">
						<a class="mobile-brand" href="/" aria-label="Go to homepage">
							<Image class="mobile-brand-logo" src={logo} width={42} height={42} alt="" />
							<span class="mobile-brand-copy">
								<span class="mobile-brand-name" style="color: var(--color-accent)">Alfredo Navas</span>
								<span class="mobile-brand-role">Product Builder</span>
							</span>
						</a>
						<button
							class="sidebar-toggle"
							type="button"
							aria-label="Open navigation menu"
							aria-controls="primary-sidebar"
							aria-expanded="false"
							data-sidebar-toggle
						>
							<span class="sidebar-toggle-line" aria-hidden="true"></span>
							<span class="sidebar-toggle-line" aria-hidden="true"></span>
							<span class="sidebar-toggle-line" aria-hidden="true"></span>
						</button>
					</header>

					<main class:list={['content', isEdgeContentLayout && 'content-edge']}>
						<div class:list={['content-inner', isEdgeContentLayout && 'content-inner-edge']}>
							<slot />
						</div>
					</main>

					{
						showCli && (
							<section
								class="cli"
								aria-label="Command line interface"
								data-page={currentPage}
								data-page-context={encodeURIComponent(pageContext)}
							>
								<div class="cli-panel">
									<div class="cli-box">
										<button
											class="cli-dismiss"
											id="cli-dismiss"
											type="button"
											aria-label="Collapse response panel"
										>
											<svg viewBox="0 0 24 24" aria-hidden="true">
												<path
													d="m7 7 10 10M17 7 7 17"
													fill="none"
													stroke="currentColor"
													stroke-linecap="round"
													stroke-width="1.8"
												/>
											</svg>
										</button>
										<div class="cli-messages" id="cli-messages"></div>
										<form class="cli-row" id="cli-form">
											<span class="cli-prompt-marker" aria-hidden="true">
												<svg viewBox="0 0 24 24">
													<path
														d="M12 5v14M5 12h14"
														fill="none"
														stroke="currentColor"
														stroke-linecap="round"
														stroke-width="1.8"
													/>
												</svg>
											</span>
											<input
												class="cli-input"
												id="cli-input"
												name="question"
												type="text"
												placeholder="Ask me anything..."
												aria-label="Ask me anything"
												autocomplete="off"
												required
											/>
											<button class="cli-btn cli-btn-send" type="submit" aria-label="Send">
												<svg viewBox="0 0 24 24">
													<use href="#icon-send" />
												</svg>
											</button>
										</form>
									</div>
									<p class="cli-hint">
										Try: <span>about</span>, <span>projects</span>, <span>experience</span>
									</p>
								</div>
							</section>
						)
					}
				</div>

				<svg class="icon-defs" aria-hidden="true" focusable="false">
					<defs>
						<symbol id="icon-home" viewBox="0 0 24 24">
							<path
								d="M4 11.2 12 5l8 6.2V20a1 1 0 0 1-1 1h-4.5v-5h-5v5H5a1 1 0 0 1-1-1v-8.8Z"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-about" viewBox="0 0 24 24">
							<path
								d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-projects" viewBox="0 0 24 24">
							<path
								d="M8 4h8l4 4v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h3Zm4 0v4h4"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-blog" viewBox="0 0 24 24">
							<path
								d="M7 3h8l5 5v13H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm8 0v5h5M9 13h6M9 17h6"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-contact" viewBox="0 0 24 24">
							<path
								d="M4 6h16v12H4zM4 7l8 6 8-6"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-web" viewBox="0 0 24 24">
							<path
								d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18M4.8 7.5h14.4M4.8 16.5h14.4"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-mic" viewBox="0 0 24 24">
							<path
								d="M12 3a3 3 0 0 1 3 3v6a3 3 0 1 1-6 0V6a3 3 0 0 1 3-3Zm0 14v4m-5-7a5 5 0 0 0 10 0"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
						<symbol id="icon-send" viewBox="0 0 24 24">
							<path
								d="m12 5 7 7m-7-7-7 7m7-7v14"
								fill="none"
								stroke="currentColor"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="1.8"
							/>
						</symbol>
					</defs>
				</svg>
			</div>
			<script>
				const MAX_HISTORY_EXCHANGES = 3;
				const MAX_HISTORY_MESSAGES = MAX_HISTORY_EXCHANGES * 2;
				const form = document.querySelector('#cli-form');
				const input = document.querySelector('#cli-input');
				const messages = document.querySelector('#cli-messages');
				const cliRoot = document.querySelector('.cli');
				const cliPanel = cliRoot?.querySelector('.cli-panel');
				const shellRoot = document.querySelector('[data-sidebar-shell]');
				const dismissButton = document.querySelector('#cli-dismiss');
				const page = cliRoot?.dataset.page ?? '/';
				const encodedPageContext = cliRoot?.dataset.pageContext ?? '';
				let pageContext = '';

				if (encodedPageContext) {
					try {
						pageContext = decodeURIComponent(encodedPageContext);
					} catch {
						pageContext = '';
					}
				}

				const submitButton = form?.querySelector('.cli-btn-send');

				if (form && input && messages && submitButton) {
					const conversationHistory = [];
					let activeRevealId = 0;
					let isDockExpanded = false;
					let idleDockHeight = 0;
					let heroOffsetFrame = 0;
					const desktopHeroQuery = window.matchMedia('(max-width: 48rem)');
					const heroBreathingRoom = 18;
					const maxHeroLift = 180;
					const assistantLinkPattern =
						/(https?:\/\/[^\s<>"']+)|(\/[a-zA-Z0-9][a-zA-Z0-9/_-]*)/g;
					const trailingPunctuationPattern = /[.,!?;:)\]]+$/;

					const addHistoryMessage = (role, content) => {
						const normalizedRole = role === 'user' || role === 'assistant' ? role : null;
						const normalizedContent = typeof content === 'string' ? content.trim() : '';

						if (!normalizedRole || !normalizedContent) {
							return;
						}

						conversationHistory.push({ role: normalizedRole, content: normalizedContent });
						if (conversationHistory.length > MAX_HISTORY_MESSAGES) {
							conversationHistory.splice(0, conversationHistory.length - MAX_HISTORY_MESSAGES);
						}
					};

					const getHistoryForRequest = () => conversationHistory.slice(-MAX_HISTORY_MESSAGES);

					/**
					 * Renders assistant text into a container and converts URL-like substrings
					 * to clickable links while preserving trailing punctuation.
					 */
					const appendAssistantTextWithLinks = (container, paragraph) => {
						let lastIndex = 0;

						for (const match of paragraph.matchAll(assistantLinkPattern)) {
							const index = match.index ?? 0;
							const rawLink = match[0];

							if (index > lastIndex) {
								container.append(document.createTextNode(paragraph.slice(lastIndex, index)));
							}

							let href = rawLink;
							let trailing = '';
							const trailingMatch = rawLink.match(trailingPunctuationPattern);

							if (trailingMatch) {
								trailing = trailingMatch[0];
								href = rawLink.slice(0, -trailing.length);
							}

							if (href) {
								const link = document.createElement('a');
								link.href = href;
								if (href.startsWith('http://') || href.startsWith('https://')) {
									link.target = '_blank';
									link.rel = 'noopener noreferrer';
								}
								link.textContent = href;
								container.append(link);
							}

							if (trailing) {
								container.append(document.createTextNode(trailing));
							}

							lastIndex = index + rawLink.length;
						}

						if (lastIndex < paragraph.length) {
							container.append(document.createTextNode(paragraph.slice(lastIndex)));
						}
					};

					/**
					 * Keeps the latest CLI message visible after updates.
					 */
					const scrollMessages = () => {
						messages.scrollTop = messages.scrollHeight;
					};

					const setDockExpanded = (expanded) => {
						isDockExpanded = expanded;
						if (shellRoot) {
							shellRoot.dataset.cliExpanded = expanded ? 'true' : 'false';
						}
						scheduleHeroDockCompensation();
					};

					const applyHeroDockCompensation = () => {
						if (!shellRoot || !cliPanel) {
							return;
						}

						const isDesktop = !desktopHeroQuery.matches;
						const isHomePage = shellRoot.dataset.home === 'true';

						if (!isDesktop || !isHomePage) {
							shellRoot.style.setProperty('--home-hero-lift', '0px');
							return;
						}

						const currentDockHeight = cliPanel.getBoundingClientRect().height;
						if (!messages.children.length) {
							idleDockHeight = currentDockHeight;
							shellRoot.style.setProperty('--home-hero-lift', '0px');
							return;
						}

						if (idleDockHeight <= 0) {
							idleDockHeight = currentDockHeight;
						}

						const dockGrowth = Math.max(0, currentDockHeight - idleDockHeight);
						const heroLift = Math.min(maxHeroLift, dockGrowth + heroBreathingRoom);
						shellRoot.style.setProperty('--home-hero-lift', `${heroLift}px`);
					};

					const scheduleHeroDockCompensation = () => {
						if (heroOffsetFrame) {
							window.cancelAnimationFrame(heroOffsetFrame);
						}

						heroOffsetFrame = window.requestAnimationFrame(() => {
							heroOffsetFrame = 0;
							applyHeroDockCompensation();
						});
					};

					const collapseCliDock = () => {
						setDockExpanded(false);
					};

					/**
					 * Replaces a message node with either loading feedback or paragraph content.
					 * Assistant messages support multiline formatting and inline link detection.
					 */
					const renderMessageContent = (item, role, text, isLoading = false) => {
						item.replaceChildren();

						if (isLoading) {
							const loader = document.createElement('span');
							loader.className = 'cli-loader';
							loader.setAttribute('aria-label', 'Assistant is typing');

							for (let i = 0; i < 3; i += 1) {
								const dot = document.createElement('span');
								dot.className = 'cli-loader-dot';
								loader.append(dot);
							}

							item.append(loader);
							return;
						}

						const value = typeof text === 'string' ? text.trim() : '';
						const paragraphs =
							role === 'assistant'
								? value.split(/\n+/).map((paragraph) => paragraph.trim()).filter(Boolean)
								: [value];

						paragraphs.forEach((paragraph) => {
							const block = document.createElement('p');
							block.className = 'cli-message-paragraph';

							if (role === 'assistant') {
								appendAssistantTextWithLinks(block, paragraph);
							} else {
								block.textContent = paragraph;
							}

							item.append(block);
						});
					};

					/**
					 * Appends a chat bubble for the given role and returns its DOM node
					 * so callers can progressively update it.
					 */
					const appendMessage = (role, text, isLoading = false) => {
						const item = document.createElement('div');
						item.className = `cli-message cli-message-${role}`;
						renderMessageContent(item, role, text, isLoading);
						messages.append(item);
						scrollMessages();
						scheduleHeroDockCompensation();
						return item;
					};

					const wait = (ms) => new Promise((resolve) => window.setTimeout(resolve, ms));

					const revealAssistantResponse = async (item, text) => {
						activeRevealId += 1;
						const revealId = activeRevealId;
						const response = typeof text === 'string' ? text : '';
						const normalized = response.trim();

						if (!normalized) {
							renderMessageContent(item, 'assistant', response);
							scrollMessages();
							return response;
						}

						const totalLength = normalized.length;
						let visibleLength = 0;

						while (visibleLength < totalLength && revealId === activeRevealId) {
							const remaining = totalLength - visibleLength;
							const chunk = Math.min(remaining, Math.max(6, Math.round(totalLength / 26)));
							visibleLength += chunk;
							renderMessageContent(item, 'assistant', normalized.slice(0, visibleLength));
							scrollMessages();
							await wait(22);
						}

						renderMessageContent(item, 'assistant', normalized);
						scrollMessages();
						return normalized;
					};

					if (cliPanel) {
						scheduleHeroDockCompensation();
						if ('ResizeObserver' in window) {
							const panelResizeObserver = new ResizeObserver(() => {
								scheduleHeroDockCompensation();
							});
							panelResizeObserver.observe(cliPanel);
						}
						window.addEventListener('resize', scheduleHeroDockCompensation);
						desktopHeroQuery.addEventListener('change', scheduleHeroDockCompensation);
					}

					form.addEventListener('submit', async (event) => {
						event.preventDefault();
						const question = input.value.trim();

						if (!question) {
							return;
						}

						setDockExpanded(true);
						appendMessage('user', question);
						addHistoryMessage('user', question);
						const assistantMessage = appendMessage('assistant', '', true);
						input.value = '';
						input.disabled = true;
						submitButton.disabled = true;

						try {
							const conversationHistoryPayload = getHistoryForRequest();
							const requestBody = pageContext
								? { question, page, pageContext, conversationHistory: conversationHistoryPayload }
								: { question, page, conversationHistory: conversationHistoryPayload };
							if (import.meta.env.DEV) {
								console.debug('[cli] /api/ask payload', {
									question,
									page,
									pageContextPreview: pageContext.slice(0, 240),
									historyCount: conversationHistoryPayload.length,
								});
							}

							const response = await fetch('/api/ask', {
								method: 'POST',
								headers: { 'Content-Type': 'application/json' },
								body: JSON.stringify(requestBody),
							});
							const payload = await response.json();
							const text = typeof payload.text === 'string' ? payload.text : "I don't know.";
							const finalText = await revealAssistantResponse(assistantMessage, text);
							addHistoryMessage('assistant', finalText);
						} catch {
							activeRevealId += 1;
							renderMessageContent(assistantMessage, 'assistant', 'Something went wrong. Please try again.');
							scrollMessages();
						} finally {
							input.disabled = false;
							submitButton.disabled = false;
							input.focus();
						}
					});

					if (dismissButton instanceof HTMLButtonElement) {
						dismissButton.addEventListener('click', collapseCliDock);
					}
				}

				const sidebarRoots = document.querySelectorAll('[data-sidebar-shell]');
				const mobileSidebarQuery = window.matchMedia('(max-width: 48rem)');
				const sidebarSearchIndexNode = document.querySelector('#sidebar-search-index');
				let sidebarSearchIndex = [];

				if (sidebarSearchIndexNode?.textContent) {
					try {
						const parsed = JSON.parse(sidebarSearchIndexNode.textContent);
						if (Array.isArray(parsed)) {
							sidebarSearchIndex = parsed;
						}
					} catch {
						sidebarSearchIndex = [];
					}
				}

				const normalizeSearchValue = (value) =>
					(typeof value === 'string' ? value.toLowerCase().trim() : '');

				sidebarRoots.forEach((root) => {
					if (root.dataset.sidebarBound === 'true') {
						return;
					}

					root.dataset.sidebarBound = 'true';
					const sidebar = root.querySelector('[data-mobile-sidebar]');
					const toggle = root.querySelector('[data-sidebar-toggle]');
					const backdrop = root.querySelector('[data-sidebar-backdrop]');
					const navLinks = root.querySelectorAll('.nav-link');
					const searchInput = root.querySelector('[data-sidebar-search-input]');
					const searchDropdown = root.querySelector('[data-sidebar-search-dropdown]');
					const searchResults = root.querySelector('[data-sidebar-search-results]');

					if (!(sidebar instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) {
						return;
					}

					if (
						searchInput instanceof HTMLInputElement &&
						searchDropdown instanceof HTMLElement &&
						searchResults instanceof HTMLElement
					) {
						const searchWrap = searchInput.closest('.search-wrap');
						const closeAndResetSearch = () => {
							searchInput.value = '';
							searchDropdown.hidden = true;
							searchResults.replaceChildren();
						};

						const renderSearchResults = (query) => {
							const normalizedQuery = normalizeSearchValue(query);
							searchResults.replaceChildren();

							if (!normalizedQuery) {
								searchDropdown.hidden = true;
								return;
							}

							const matches = sidebarSearchIndex
								.filter((entry) => {
									const title = normalizeSearchValue(entry.title);
									const description = normalizeSearchValue(entry.description);
									const tags = Array.isArray(entry.tags)
										? entry.tags.map((tag) => normalizeSearchValue(tag)).join(' ')
										: '';
									const type = normalizeSearchValue(entry.type);
									const haystack = `${title} ${description} ${tags} ${type}`;
									return haystack.includes(normalizedQuery);
								})
								.slice(0, 7);

							searchDropdown.hidden = false;

							if (!matches.length) {
								const emptyItem = document.createElement('li');
								emptyItem.className = 'search-empty';
								emptyItem.textContent = 'No direct matches. Try asking me below.';
								searchResults.append(emptyItem);
								return;
							}

							matches.forEach((entry) => {
								const item = document.createElement('li');
								const link = document.createElement('a');
								const label = document.createElement('span');

								link.href = entry.url;
								link.className = 'search-result-link';

								label.className = 'search-result-title';
								label.textContent = entry.title;

								link.append(label);
								item.append(link);
								searchResults.append(item);
							});
						};

						searchInput.addEventListener('focus', () => {
							renderSearchResults(searchInput.value);
						});

						searchInput.addEventListener('input', () => {
							renderSearchResults(searchInput.value);
						});

						searchInput.addEventListener('keydown', (event) => {
							if (event.key === 'Escape') {
								closeAndResetSearch();
								searchInput.blur();
							}
						});

						searchResults.addEventListener('click', (event) => {
							const target = event.target;
							if (!(target instanceof Element)) {
								return;
							}

							const selectedResult = target.closest('.search-result-link');
							if (selectedResult) {
								closeAndResetSearch();
							}
						});

						document.addEventListener('pointerdown', (event) => {
							if (!(event.target instanceof Node)) {
								return;
							}

							if (searchWrap && !searchWrap.contains(event.target)) {
								closeAndResetSearch();
							}
						});
					}

					/**
					 * Centralizes sidebar state changes and accessibility attributes
					 * for desktop and mobile behavior.
					 */
					const syncSidebarState = (open) => {
						const isMobile = mobileSidebarQuery.matches;
						root.dataset.sidebarOpen = open ? 'true' : 'false';
						toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
						toggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');

						if (!isMobile) {
							sidebar.setAttribute('aria-hidden', 'false');
							sidebar.removeAttribute('inert');
							document.body.style.removeProperty('overflow');
							return;
						}

						sidebar.setAttribute('aria-hidden', open ? 'false' : 'true');
						if (open) {
							sidebar.removeAttribute('inert');
							document.body.style.overflow = 'hidden';
						} else {
							sidebar.setAttribute('inert', '');
							document.body.style.removeProperty('overflow');
						}
					};

					/**
					 * Convenience wrapper used by all close interactions.
					 */
					const closeSidebar = () => {
						syncSidebarState(false);
					};

					toggle.addEventListener('click', () => {
						const nextOpen = root.dataset.sidebarOpen !== 'true';
						syncSidebarState(nextOpen);
					});

					backdrop?.addEventListener('click', closeSidebar);

					navLinks.forEach((link) => {
						link.addEventListener('click', () => {
							if (mobileSidebarQuery.matches) {
								closeSidebar();
							}
						});
					});

					document.addEventListener('pointerdown', (event) => {
						if (!mobileSidebarQuery.matches || root.dataset.sidebarOpen !== 'true') {
							return;
						}

						if (sidebar.contains(event.target) || toggle.contains(event.target)) {
							return;
						}

						closeSidebar();
					});

					document.addEventListener('keydown', (event) => {
						if (event.key === 'Escape' && root.dataset.sidebarOpen === 'true') {
							closeSidebar();
							toggle.focus();
						}
					});

					mobileSidebarQuery.addEventListener('change', () => {
						syncSidebarState(false);
					});

					syncSidebarState(false);
				});
			</script>
		</body>
